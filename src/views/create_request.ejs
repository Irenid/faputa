<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8"><title>Новая заявка</title>
    <link href="/public/bootstrap.min.css" rel="stylesheet">
    <script src="/public/htmx.min.js"></script>
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh;">
<div class="card shadow p-4 bg-white" style="max-width: 500px; width: 100%; border-radius: 12px;">
    <h3 class="mb-4 text-center fw-bold text-success">Сформировать заявку</h3>

    <form hx-post="/requests/create-request">
        <div class="mb-3">
            <label class="form-label">Наименование курса</label>
            <input type="text" name="courseName" class="form-control" placeholder="Введите название курса" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Желаемая дата начала обучения</label>
            <input type="date" name="startDate" class="form-control" required>
        </div>

        <div class="mb-4">
            <label class="form-label">Способ оплаты</label>
            <select name="payMethod" class="form-select" required>
                <option value="наличными">Наличными</option>
                <option value="переводом">Переводом по номеру телефона</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success w-100 py-2 fw-bold">Отправить</button>
            <a href="/requests/my-requests" class="btn btn-light w-50 py-2">Назад</a>
        </div>
    </form>
</div>
</body>
</html>