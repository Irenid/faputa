<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8"><title>Мои Заявки</title>
    <link href="/public/bootstrap.min.css" rel="stylesheet">
    <script src="/public/htmx.min.js"></script>
</head>
<body class="bg-light p-4">
<div class="container" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Мои заявки на обучение</h2>
        <a href="/requests/create-request" class="btn btn-primary">+ Новая заявка</a>
    </div>

    <% if (requests.length === 0) { %>
        <div class="alert alert-info">Вы еще не отправляли заявок.</div>
    <% } %>

    <% requests.forEach(req => { %>
        <div class="card shadow-sm mb-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title mb-1 text-primary"><%= req.courseName %></h5>
                    <p class="text-muted small mb-1">
                        Дата старта: <%= new Date(req.startDate).toLocaleDateString('ru-RU') %> |
                        Оплата: <%= req.paymentType === 'CASH' ? 'Наличными' : 'Переводом по телефону' %>
                    </p>

                    <div id="review-zone-<%= req.id %>" class="mt-2">
                        <% if (req.review) { %>
                            <span class="text-muted fst-italic">Ваш отзыв: <%= req.review %></span>
                        <% } else if (req.status === 'COMPLETED') { %>
                            <form hx-post="/requests/request/<%= req.id %>/review" hx-target="#review-zone-<%= req.id %>" hx-swap="outerHTML" class="input-group input-group-sm" style="max-width: 400px;">
                                <input type="text" name="review" class="form-control" placeholder="Оставьте отзыв о качестве услуг" required>
                                <button class="btn btn-outline-success" type="submit">Отправить</button>
                            </form>
                        <% } %>
                    </div>
                </div>

                <div>
            <span class="badge <%= req.status === 'NEW' ? 'bg-primary' : req.status === 'TRAINING' ? 'bg-warning text-dark' : 'bg-success' %> py-2 px-3">
              <%= req.status === 'NEW' ? 'Новая' : req.status === 'TRAINING' ? 'Идет обучение' : 'Обучение завершено' %>
            </span>
                </div>
            </div>
        </div>
    <% }) %>
</div>
</body>
</html>