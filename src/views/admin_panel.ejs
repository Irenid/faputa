<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8"><title>Панель администратора</title>
    <link href="/public/bootstrap.min.css" rel="stylesheet">
    <script src="/public/htmx.min.js"></script>
</head>
<body class="bg-dark text-white p-4">
<div class="container bg-secondary p-4 rounded shadow" style="max-width: 1100px;">
    <h2 class="mb-4 border-bottom pb-2 fw-bold">Панель администратора</h2>

    <div class="table-responsive text-dark">
        <table class="table table-striped table-hover bg-white rounded overflow-hidden align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Курс</th>
                    <th>Дата старта</th>
                    <th>Оплата</th>
                    <th>Отзыв</th>
                    <th style="width: 240px;">Статус и Действия</th>
                </tr>
            </thead>
            <tbody>
                <% requests.forEach(req => { %>
                    <tr>
                        <td><strong><%= req.courseName %></strong></td>
                        <td><%= new Date(req.startDate).toLocaleDateString('ru-RU') %></td>
                        <td><small><%= req.paymentType === 'CASH' ? 'Наличные' : 'Телефон' %></small></td>
                        <td><span class="fst-italic text-muted"><%= req.review ? req.review : '—' %></span></td>

                        <td hx-target="this" hx-swap="innerHTML">
                <span class="badge <%= req.status === 'NEW' ? 'bg-primary' : req.status === 'TRAINING' ? 'bg-warning text-dark' : 'bg-success' %> mb-2 d-inline-block">
                  <%= req.status === 'NEW' ? 'Новая' : req.status === 'TRAINING' ? 'Идет обучение' : 'Обучение завершено' %>
                </span>
                            <div class="btn-group btn-group-sm d-block">
                                <button class="btn btn-outline-warning" hx-post="/requests/admin/request/<%= req.id %>/status" hx-vals='{"status": "TRAINING"}'>Обучение</button>
                                <button class="btn btn-outline-success" hx-post="/requests/admin/request/<%= req.id %>/status" hx-vals='{"status": "COMPLETED"}'>Завершить</button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
</body>
</html>